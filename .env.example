# MentorBoxAI Environment Variables
# Copy this file to .env and fill in actual values

# ===================
# Amazon Bedrock / Nova 2 Lite (REQUIRED)
# Authentication: attach an IAM role with BedrockInvokeModel permission
# to the EC2 instance — no API keys needed here.
# ===================
AWS_REGION=us-east-1
NOVA_MODEL_ID=amazon.nova-pro-v1:0

# ===================
# LLM Settings
# ===================
LLM_GENERATOR_MAX_TOKENS=4096
LLM_GENERATOR_TEMPERATURE=0.01

# ===================
# AWS (S3, DynamoDB, Lambda)
# If running on EC2 with IAM role, leave these blank.
# ===================
# AWS_ACCESS_KEY_ID=your_access_key      # Only needed locally
# AWS_SECRET_ACCESS_KEY=your_secret_key  # Only needed locally
S3_BUCKET=mentorboxai-nova-videos

# ===================
# API Server
# ===================
PORT=8000
NODE_ENV=production
CORS_ORIGIN=https://yourdomain.com
